      '🧛 吸血っ子特化コレクション',
      '🪆 人形っ子特化コレクション'
    ];
    specialRoot.children.sort(function(a, b){
      var ai = preferred.indexOf(titleOf(a));
      var bi = preferred.indexOf(titleOf(b));
      if (ai < 0) ai = 999;
      if (bi < 0) bi = 999;
      return ai - bi;
    });

    var mythicPack = db[MYTHIC_PACK_KEY];
    if (isArray(mythicPack)) db[MYTHIC_PACK_KEY] = filterOutLegacy(mythicPack);

    var mythicNode = findByTitle(roleplayRoot, '神獣・伝説なりきり');
    if (mythicNode && isArray(mythicNode.children)) mythicNode.children = filterOutLegacy(mythicNode.children);

    if (mythicNode && isArray(mythicNode.children) && mythicNode.children.length === 0 && isArray(roleplayRoot.children)) {
      roleplayRoot.children = roleplayRoot.children.filter(function(node){ return node !== mythicNode; });
    }

    if (window.__PP_DB) window.__PP_DB.packs = db;
    window.PRESET_PACKS_DB = db;
    window.__PRESET_PACKS_DB = db;
  } catch (e) {}
})();


