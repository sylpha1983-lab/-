    if (!roleplayRoot || !isArray(roleplayRoot.children)) return;

    var specialRoot = findByTitle(roleplayRoot, SPECIAL_TITLE_JA);
    if (!specialRoot) return;
    if (!isArray(specialRoot.children)) specialRoot.children = [];

    upsertByTitle(specialRoot.children, fourSymbolsNode);

    var preferred = [
      FOUR_TITLE_JA,
      '🐉 ドラゴンっ子特化コレクション',
      '😈 悪魔っ子特化コレクション',
