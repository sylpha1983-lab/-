(function(){
  "use strict";
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) ? window.__PP_DB.packs
      : (window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB || null);
    if (!db) return;

    var adminKey = "🎭 なりきりおすすめセット｜管理者専用なりきり (Admin-only Roleplay)";
    var roleplayParentKey = "🎭 なりきりおすすめセット (Roleplay Recommended Sets)";
    var adminRoot = (db[adminKey] && db[adminKey][0]) ? db[adminKey][0] : null;
    if (!adminRoot || !adminRoot.children) return;

    function isArray(v){ return Object.prototype.toString.call(v) === "[object Array]"; }
    function titleOf(node){ return String((node && (node.title_ja || node.titleJa || node.label || "")) || ""); }
    function cloneNode(node){
      if (!node || typeof node !== "object") return node;
      var out = {};
      var keys = Object.keys(node);
      for (var i = 0; i < keys.length; i++) {
        var k = keys[i];
        var v = node[k];
        if (isArray(v)) {
          var arr = [];
          for (var j = 0; j < v.length; j++) arr.push(cloneNode(v[j]));
          out[k] = arr;
        } else if (v && typeof v === "object") {
          out[k] = cloneNode(v);
        } else {
          out[k] = v;
        }
      }
      return out;
    }
    function findChildByTitle(list, title){
      if (!isArray(list)) return null;
      for (var i = 0; i < list.length; i++) if (titleOf(list[i]) === title) return list[i];
      return null;
    }
    function bucketForId(id){
      id = String(id || "");
      if (!id) return "core";
      if (id.indexOf("default") !== -1 || id.indexOf("core") !== -1 || id.indexOf("draconic") !== -1 || id.indexOf("scale") !== -1 || id.indexOf("horns") !== -1 || id.indexOf("aura") !== -1) return "core";
      if (id.indexOf("crimson") !== -1 || id.indexOf("solar") !== -1 || id.indexOf("volcanic") !== -1 || id.indexOf("inferno") !== -1 || id.indexOf("sunflare") !== -1 || id.indexOf("goldbloom") !== -1 || id.indexOf("magmabloom") !== -1 || id.indexOf("ashburst") !== -1) return "flame";
      if (id.indexOf("frost") !== -1 || id.indexOf("aurora") !== -1 || id.indexOf("polarspark") !== -1 || id.indexOf("frostmist") !== -1) return "frost";
      if (id.indexOf("storm") !== -1 || id.indexOf("wind") !== -1 || id.indexOf("lightning") !== -1 || id.indexOf("gale") !== -1 || id.indexOf("airstreak") !== -1 || id.indexOf("windflow") !== -1) return "storm";
      if (id.indexOf("earth") !== -1 || id.indexOf("dune") !== -1 || id.indexOf("rockplate") !== -1 || id.indexOf("dustveil") !== -1 || id.indexOf("sandsheen") !== -1 || id.indexOf("heatmirage") !== -1) return "earth";
      if (id.indexOf("tide") !== -1 || id.indexOf("caustics") !== -1 || id.indexOf("seamist") !== -1) return "tide";
      if (id.indexOf("venom") !== -1 || id.indexOf("verdant") !== -1 || id.indexOf("toxicglow") !== -1 || id.indexOf("poisonpetals") !== -1 || id.indexOf("leafglow") !== -1 || id.indexOf("pollenveil") !== -1) return "nature";
      if (id.indexOf("holy") !== -1 || id.indexOf("crystal") !== -1 || id.indexOf("halo") !== -1 || id.indexOf("sacredgold") !== -1 || id.indexOf("refraction") !== -1 || id.indexOf("facetshine") !== -1) return "holy";
      if (id.indexOf("abyss") !== -1 || id.indexOf("eclipse") !== -1 || id.indexOf("voidbloom") !== -1 || id.indexOf("darkpressure") !== -1 || id.indexOf("eclipsering") !== -1 || id.indexOf("moonshadow") !== -1) return "abyss";
      if (id.indexOf("metal") !== -1 || id.indexOf("steelscale") !== -1 || id.indexOf("forgelight") !== -1) return "metal";
      return "misc";
    }

    var dragonNode = findChildByTitle(adminRoot.children, "🐉 ドラゴンっ子");
    if (!dragonNode || !isArray(dragonNode.children)) return;
    var attrNode = findChildByTitle(dragonNode.children, "🌩 属性竜コレクション");
    if (!attrNode || !isArray(attrNode.children)) return;
    if (findChildByTitle(attrNode.children, "🐉 基本竜群")) return;

    var specs = [
      { key: "core", title_ja: "🐉 基本竜群", title_en: "Core Dragon Cluster" },
      { key: "flame", title_ja: "🔥 炎陽竜群", title_en: "Flame & Solar Dragons" },
      { key: "frost", title_ja: "❄ 氷極竜群", title_en: "Frost & Aurora Dragons" },
      { key: "storm", title_ja: "⚡ 雷風竜群", title_en: "Storm & Gale Dragons" },
      { key: "earth", title_ja: "⛰ 地砂竜群", title_en: "Earth & Dune Dragons" },
      { key: "tide", title_ja: "🌊 潮流竜群", title_en: "Tide Dragons" },
      { key: "nature", title_ja: "☠🌿 毒花森竜群", title_en: "Venom, Bloom & Verdant Dragons" },
      { key: "holy", title_ja: "✨ 聖晶竜群", title_en: "Holy & Crystal Dragons" },
      { key: "abyss", title_ja: "🌑 冥蝕竜群", title_en: "Abyss & Eclipse Dragons" },
      { key: "metal", title_ja: "⚙ 鋼鎧竜群", title_en: "Metal Dragons" },
      { key: "misc", title_ja: "🜂 混成属性竜群", title_en: "Mixed Attribute Dragons" }
    ];
    var groups = [];
    for (var gi = 0; gi < specs.length; gi++) groups.push({ key: specs[gi].key, title_ja: specs[gi].title_ja, title_en: specs[gi].title_en, children: [] });

    for (var si = 0; si < attrNode.children.length; si++) {
      var section = attrNode.children[si];
      if (!section || !isArray(section.children)) continue;
      var sectionJa = section.title_ja || section.titleJa || "";
      var sectionEn = section.title_en || section.titleEn || "";
      for (var gj = 0; gj < groups.length; gj++) {
        var picked = [];
        for (var ii = 0; ii < section.children.length; ii++) {
          var item = section.children[ii];
          var id = String((item && item.id) || "");
          if (!id || id.indexOf("admin_dragon_") !== 0) continue;
          if (bucketForId(id) === groups[gj].key) picked.push(cloneNode(item));
        }
        if (picked.length) {
          groups[gj].children.push({
            title_ja: sectionJa,
            title_en: sectionEn,
            children: picked
          });
        }
      }
    }

    attrNode.children = [];
    for (var gk = 0; gk < groups.length; gk++) {
      if (groups[gk].children && groups[gk].children.length) attrNode.children.push(groups[gk]);
    }

    function syncAdminNodeChildren(node){
      if (!node || !adminRoot) return;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) syncAdminNodeChildren(node[i]);
        return;
      }
      if (typeof node !== "object") return;
      if (titleOf(node) === "🛡 管理者専用なりきり特化コレクション") {
        node.children = adminRoot.children;
      }
      var keys = Object.keys(node);
      for (var j = 0; j < keys.length; j++) syncAdminNodeChildren(node[keys[j]]);
    }

    if (db[roleplayParentKey]) syncAdminNodeChildren(db[roleplayParentKey]);
    if (window.__PP_DB) window.__PP_DB.packs = db;
    if (window.PRESET_PACKS_DB) window.PRESET_PACKS_DB = db;
    if (window.__PRESET_PACKS_DB) window.__PRESET_PACKS_DB = db;
  } catch (e) {}
})();


