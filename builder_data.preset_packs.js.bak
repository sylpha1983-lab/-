(function(){
  "use strict";
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) ? window.__PP_DB.packs
      : (window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB || null);
    if (!db) return;

    var adminKey = "🎭 なりきりおすすめセット｜管理者専用なりきり (Admin-only Roleplay)";
    var roleplayParentKey = "🎭 なりきりおすすめセット (Roleplay Recommended Sets)";
    var adminRoot = (db[adminKey] && db[adminKey][0]) ? db[adminKey][0] : null;
    if (!adminRoot || !adminRoot.children) return;

    function isArray(v){ return Object.prototype.toString.call(v) === "[object Array]"; }
    function titleOf(node){ return String((node && (node.title_ja || node.titleJa || node.label || "")) || ""); }
    function cloneNode(node){
      if (!node || typeof node !== "object") return node;
      var out = {};
      var keys = Object.keys(node);
      for (var i = 0; i < keys.length; i++) {
        var k = keys[i];
        var v = node[k];
        if (isArray(v)) {
          var arr = [];
          for (var j = 0; j < v.length; j++) arr.push(cloneNode(v[j]));
          out[k] = arr;
        } else if (v && typeof v === "object") {
          out[k] = cloneNode(v);
        } else {
          out[k] = v;
        }
      }
      return out;
    }
    function findChildByTitle(list, title){
      if (!isArray(list)) return null;
      for (var i = 0; i < list.length; i++) if (titleOf(list[i]) === title) return list[i];
      return null;
    }
    function bucketForId(id){
      id = String(id || "");
      if (!id) return "mythic";
      if (id.indexOf("bahamut") !== -1 || id.indexOf("shinryu") !== -1 || id.indexOf("quetzalcoatl") !== -1) return "holy";
      if (id.indexOf("diabolos") !== -1 || id.indexOf("nidhogg") !== -1 || id.indexOf("vritra") !== -1 || id.indexOf("azi_dahaka") !== -1 || id.indexOf("apophis") !== -1 || id.indexOf("zahhak") !== -1) return "abyss";
      if (id.indexOf("tiamat") !== -1 || id.indexOf("midgardsormr") !== -1 || id.indexOf("leviathan") !== -1) return "origin";
      if (id.indexOf("jormungandr") !== -1 || id.indexOf("orochi") !== -1 || id.indexOf("hydra") !== -1 || id.indexOf("ananta") !== -1 || id.indexOf("ouroboros") !== -1) return "serpent";
      if (id.indexOf("fafnir") !== -1) return "treasure";
      if (id.indexOf("alduin") !== -1) return "mythic";
      return "mythic";
    }

    var dragonNode = findChildByTitle(adminRoot.children, "🐉 ドラゴンっ子");
    if (!dragonNode || !isArray(dragonNode.children)) return;
    var namedNode = findChildByTitle(dragonNode.children, "🏛 固有名・神話竜コレクション");
    if (!namedNode || !isArray(namedNode.children)) return;
    if (findChildByTitle(namedNode.children, "👑 神聖覇竜群")) return;

    var specs = [
      { key: "holy", title_ja: "👑 神聖覇竜群", title_en: "Holy Apex Dragons" },
      { key: "abyss", title_ja: "🌑 魔獄冥竜群", title_en: "Infernal & Nether Dragons" },
      { key: "origin", title_ja: "🜂 原初母竜群", title_en: "Primordial Mother Dragons" },
      { key: "serpent", title_ja: "🐍 多頭・循環蛇竜群", title_en: "Multi-headed & Cyclic Serpent Dragons" },
      { key: "treasure", title_ja: "💎 宝冠秘蔵竜群", title_en: "Treasure-hoard Dragons" },
      { key: "mythic", title_ja: "🏺 神話混成竜群", title_en: "Mixed Mythic Dragons" }
    ];
    var groups = [];
    for (var gi = 0; gi < specs.length; gi++) groups.push({ key: specs[gi].key, title_ja: specs[gi].title_ja, title_en: specs[gi].title_en, children: [] });

    for (var si = 0; si < namedNode.children.length; si++) {
      var section = namedNode.children[si];
      if (!section || !isArray(section.children)) continue;
      var sectionJa = section.title_ja || section.titleJa || "";
      var sectionEn = section.title_en || section.titleEn || "";
      for (var gj = 0; gj < groups.length; gj++) {
        var picked = [];
        for (var ii = 0; ii < section.children.length; ii++) {
          var item = section.children[ii];
          var id = String((item && item.id) || "");
          if (!id || id.indexOf("admin_dragon_named_") !== 0) continue;
          if (bucketForId(id) === groups[gj].key) picked.push(cloneNode(item));
        }
        if (picked.length) {
          groups[gj].children.push({
            title_ja: sectionJa,
            title_en: sectionEn,
            children: picked
          });
        }
      }
    }

    namedNode.children = [];
    for (var gk = 0; gk < groups.length; gk++) {
      if (groups[gk].children && groups[gk].children.length) namedNode.children.push(groups[gk]);
    }


    function serpentBucketForId(id){
      id = String(id || "");
      if (id.indexOf("orochi") !== -1) return "orochi";
      if (id.indexOf("hydra") !== -1) return "hydra";
      if (id.indexOf("ananta") !== -1 || id.indexOf("ouroboros") !== -1) return "cycle";
      if (id.indexOf("jormungandr") !== -1) return "world";
      return "other";
    }
    var serpentNode = findChildByTitle(namedNode.children, "🐍 多頭・循環蛇竜群");
    if (serpentNode && isArray(serpentNode.children) && !findChildByTitle(serpentNode.children, "⛩ 八岐祭祀蛇竜群")) {
      var serpentSpecs = [
        { key: "orochi", title_ja: "⛩ 八岐祭祀蛇竜群", title_en: "Orochi Ritual Serpents" },
        { key: "hydra", title_ja: "☠ 多首再生蛇竜群", title_en: "Hydra Regrowth Serpents" },
        { key: "cycle", title_ja: "♾ 無限循環蛇竜群", title_en: "Infinite Cycle Serpents" },
        { key: "world", title_ja: "🌊 世界環海蛇竜群", title_en: "World-Ring Sea Serpents" },
        { key: "other", title_ja: "🐍 蛇竜派生群", title_en: "Other Serpent Dragons" }
      ];
      var serpentGroups = [];
      for (var sg = 0; sg < serpentSpecs.length; sg++) serpentGroups.push({ key: serpentSpecs[sg].key, title_ja: serpentSpecs[sg].title_ja, title_en: serpentSpecs[sg].title_en, children: [] });
      for (var ss = 0; ss < serpentNode.children.length; ss++) {
        var serpentSection = serpentNode.children[ss];
        if (!serpentSection || !isArray(serpentSection.children)) continue;
        var serpentJa = serpentSection.title_ja || serpentSection.titleJa || "";
        var serpentEn = serpentSection.title_en || serpentSection.titleEn || "";
        for (var sgj = 0; sgj < serpentGroups.length; sgj++) {
          var serpentPicked = [];
          for (var sii = 0; sii < serpentSection.children.length; sii++) {
            var serpentItem = serpentSection.children[sii];
            var serpentId = String((serpentItem && serpentItem.id) || "");
            if (!serpentId || serpentId.indexOf("admin_dragon_named_") !== 0) continue;
            if (serpentBucketForId(serpentId) === serpentGroups[sgj].key) serpentPicked.push(cloneNode(serpentItem));
          }
          if (serpentPicked.length) {
            serpentGroups[sgj].children.push({
              title_ja: serpentJa,
              title_en: serpentEn,
              children: serpentPicked
            });
          }
        }
      }
      serpentNode.children = [];
      for (var sk = 0; sk < serpentGroups.length; sk++) {
        if (serpentGroups[sk].children && serpentGroups[sk].children.length) serpentNode.children.push(serpentGroups[sk]);
      }
    }

    function syncAdminNodeChildren(node){
      if (!node || !adminRoot) return;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) syncAdminNodeChildren(node[i]);
        return;
      }
      if (typeof node !== "object") return;
      if (titleOf(node) === "🛡 管理者専用なりきり特化コレクション") {
        node.children = adminRoot.children;
      }
      var keys = Object.keys(node);
      for (var j = 0; j < keys.length; j++) syncAdminNodeChildren(node[keys[j]]);
    }

    if (db[roleplayParentKey]) syncAdminNodeChildren(db[roleplayParentKey]);
    if (window.__PP_DB) window.__PP_DB.packs = db;
    if (window.PRESET_PACKS_DB) window.PRESET_PACKS_DB = db;
    if (window.__PRESET_PACKS_DB) window.__PRESET_PACKS_DB = db;
  } catch (e) {}
})();
