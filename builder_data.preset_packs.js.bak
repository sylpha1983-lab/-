    function ensureSection(parent, title){
      if (!parent) return null;
      if (!isArray(parent.children)) parent.children = [];
      var sec = findChildByTitle(parent.children, title);
      if (!sec) { sec = { title_ja: title, title_en: title, children: [] }; parent.children.push(sec); }
      if (!isArray(sec.children)) sec.children = [];
