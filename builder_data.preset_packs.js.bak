/* === Reorder Roleplay-linked Expression Support Packs === */
(function reorderRoleplayExpressionSupportPacks(){
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) ? window.__PP_DB.packs
      : (window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB || null);
    if (!db) return;

    function moveKeyAfter(obj, moveKey, anchorKey){
      if (!obj || !obj.hasOwnProperty(moveKey) || !obj.hasOwnProperty(anchorKey) || moveKey === anchorKey) return obj;
      var out = {};
      var movedVal = obj[moveKey];
      Object.keys(obj).forEach(function(k){
        if (k === moveKey) return;
        out[k] = obj[k];
        if (k === anchorKey) out[moveKey] = movedVal;
      });
      return out;
    }

    var normalKey = "🎭 なりきり連動・表情補助 (Roleplay-linked Expression Support)";
    var normalAnchor = "🎭 なりきりおすすめセット (Roleplay Recommended Sets)";
    if (db[normalKey] && db[normalAnchor]) {
      db = moveKeyAfter(db, normalKey, normalAnchor);
    }

    var adultKey = "🔞 なりきり連動・表情補助 (Adult Roleplay-linked Expression Support)";
    var adultAnchor = "🔞 なりきりおすすめセット (Adult Roleplay Recommended Sets)";
    if (db[adultKey] && db[adultAnchor]) {
      db = moveKeyAfter(db, adultKey, adultAnchor);
    }

    if (window.__PP_DB) window.__PP_DB.packs = db;
    if (window.PRESET_PACKS_DB) window.PRESET_PACKS_DB = db;
    if (window.__PRESET_PACKS_DB) window.__PRESET_PACKS_DB = db;
  } catch (e) {}
})();


/* === Normalize Admin-only Roleplay Collection species roots === */
(function normalizeAdminOnlyRoleplayCollectionSpeciesRoots(){
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) ? window.__PP_DB.packs
      : (window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB || null);
    if (!db) return;

    var SECTION_TITLES = {
      "完成セット": true,
      "ベース": true,
      "カスタマイズ": true,
      "設定": true,
      "クオリティセット": true,
      "実クオリティ項目": true
    };

    function isArray(v){ return Object.prototype.toString.call(v) === "[object Array]"; }

    function normalizeAdminNode(node){
      if (!node || !isArray(node.children)) return;
      var title = String(node.title_ja || node.titleJa || node.label || "");
      if (title !== "🛡 管理者専用なりきり特化コレクション") return;

      var existing = {};
      for (var i = 0; i < node.children.length; i++) {
        var ch0 = node.children[i];
        existing[String((ch0 && (ch0.title_ja || ch0.titleJa || ch0.label)) || "")] = true;
      }

      var hoisted = [];
      for (var j = 0; j < node.children.length; j++) {
        var species = node.children[j];
        if (!species || !isArray(species.children)) continue;
        var kept = [];
        for (var k = 0; k < species.children.length; k++) {
          var sub = species.children[k];
          var subTitle = String((sub && (sub.title_ja || sub.titleJa || sub.label)) || "");
          var isStandardSection = !!SECTION_TITLES[subTitle];
          var isNestedSpecies = !isStandardSection && sub && isArray(sub.children);
          if (isNestedSpecies) {
            if (!existing[subTitle]) {
              hoisted.push(sub);
              existing[subTitle] = true;
            }
          } else {
            kept.push(sub);
          }
        }
        species.children = kept;
      }

      if (hoisted.length) {
        node.children = node.children.concat(hoisted);
      }
    }

    function walk(node){
      if (!node) return;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) walk(node[i]);
        return;
      }
      if (typeof node !== "object") return;
      normalizeAdminNode(node);
      var keys = Object.keys(node);
      for (var j = 0; j < keys.length; j++) walk(node[keys[j]]);
    }

    walk(db);

    var adminKey = "🎭 なりきりおすすめセット｜管理者専用なりきり (Admin-only Roleplay)";
    var roleplayParentKey = "🎭 なりきりおすすめセット (Roleplay Recommended Sets)";
    var adminRoot = null;
    if (db[adminKey] && isArray(db[adminKey]) && db[adminKey][0]) adminRoot = db[adminKey][0];

    function syncAdminNodeChildren(node){
      if (!node || !adminRoot) return;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) syncAdminNodeChildren(node[i]);
        return;
      }
      if (typeof node !== "object") return;
      var title = String(node.title_ja || node.titleJa || node.label || "");
      if (title === "🛡 管理者専用なりきり特化コレクション") {
        node.children = adminRoot.children;
      }
      var keys = Object.keys(node);
      for (var j = 0; j < keys.length; j++) syncAdminNodeChildren(node[keys[j]]);
    }

    if (db[roleplayParentKey]) syncAdminNodeChildren(db[roleplayParentKey]);

    if (window.__PP_DB) window.__PP_DB.packs = db;
    if (window.PRESET_PACKS_DB) window.PRESET_PACKS_DB = db;
    if (window.__PRESET_PACKS_DB) window.__PRESET_PACKS_DB = db;
  } catch (e) {}
})();


(function(){
  "use strict";
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) ? window.__PP_DB.packs
      : (window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB || null);
    if (!db) return;

    var adminKey = "🎭 なりきりおすすめセット｜管理者専用なりきり (Admin-only Roleplay)";
    var roleplayParentKey = "🎭 なりきりおすすめセット (Roleplay Recommended Sets)";
    var adminRoot = (db[adminKey] && db[adminKey][0]) ? db[adminKey][0] : null;
    if (!adminRoot || !adminRoot.children) return;

    function isArray(v){ return Object.prototype.toString.call(v) === "[object Array]"; }
    function titleOf(node){ return String((node && (node.title_ja || node.titleJa || node.label || "")) || ""); }
    function cloneNode(it){
      var out = {};
      if (!it || typeof it !== "object") return out;
      var keys = Object.keys(it);
      for (var i = 0; i < keys.length; i++) out[keys[i]] = it[keys[i]];
      return out;
    }
    function findChildByTitle(list, title){
      if (!isArray(list)) return null;
      for (var i = 0; i < list.length; i++) if (titleOf(list[i]) === title) return list[i];
      return null;
    }

    var dragonNode = findChildByTitle(adminRoot.children, "🐉 ドラゴンっ子");
    if (!dragonNode || !isArray(dragonNode.children)) return;
    if (findChildByTitle(dragonNode.children, "🌩 属性竜コレクション")) return;

    var PARTS_KEYS = {
      crownhorn:1, brokenhorn:1, razorwing:1, veilwing:1, comettail:1, chaintail:1,
      mirrorscale:1, relicscale:1,
      horn_crown:1, horn_scars:1, wing_slicing:1, wing_starlight:1,
      tail_armor:1, tail_trails:1, scale_mirror:1, scale_relic:1,
      horncrown:1, fracturehorn:1, horns:1, wingblade:1,
      starmembrane:1, tailglow:1, rearweight:1, segmentsteel:1,
      mirrorshine:1, regalhornlight:1, keyglint:1, relicengraving:1
    };

    var ROLE_KEYS = {
      azure:1, oracle:1, nocturne:1,
      treasure:1, ruin:1, marshal:1,
      ancient:1, ancientblood:1, royalblood:1,
      guardian:1, calamity:1, slumber:1,
      hoardscholar:1, wyrmling:1, eldermentor:1,
      frenzyclaw:1, serene:1,
      blossom:1, obsidian:1
    };

    function bucketForId(id){
      id = String(id || "");
      for (var pk in PARTS_KEYS) if (id.indexOf(pk) !== -1) return "parts";
      for (var rk in ROLE_KEYS) if (id.indexOf(rk) !== -1) return "role";
      return "attribute";
    }

    var originalSections = dragonNode.children.slice();
    var groups = [
      { key: "attribute", title_ja: "🌩 属性竜コレクション", title_en: "Attribute Dragon Collection", children: [] },
      { key: "parts", title_ja: "🦴 部位特化コレクション", title_en: "Parts-specialized Collection", children: [] },
      { key: "role", title_ja: "👑 血統・役割コレクション", title_en: "Bloodline & Role Collection", children: [] }
    ];

    for (var si = 0; si < originalSections.length; si++) {
      var section = originalSections[si];
      if (!section || !isArray(section.children)) continue;
      var sectionJa = section.title_ja || section.titleJa || "";
      var sectionEn = section.title_en || section.titleEn || "";
      for (var gi = 0; gi < groups.length; gi++) {
        var picked = [];
        for (var ii = 0; ii < section.children.length; ii++) {
          var item = section.children[ii];
          var id = String((item && item.id) || "");
          if (!id || id.indexOf("admin_dragon_") !== 0) continue;
          if (bucketForId(id) === groups[gi].key) picked.push(cloneNode(item));
        }
        if (picked.length) {
          groups[gi].children.push({
            title_ja: sectionJa,
            title_en: sectionEn,
            children: picked
          });
        }
      }
    }

    dragonNode.children = groups.filter(function(g){ return g.children && g.children.length; });

    function syncAdminNodeChildren(node){
      if (!node || !adminRoot) return;
      if (isArray(node)) {
