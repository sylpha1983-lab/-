(function(){
  "use strict";
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) || window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB;
    if (!db || typeof db !== 'object') return;

    var ROLEPLAY_PARENT_KEY = '🎭 なりきりおすすめセット (Roleplay Recommended Sets)';
    var SPECIAL_TITLE_JA = '🧩 神獣・伝説特化コレクション';
    var FOUR_TITLE_JA = '☯ 四神特化コレクション';
    var QILIN_TITLE_JA = '🦌 麒麟特化コレクション';
    var QILIN_TITLE_EN = 'Qilin Special Collection';

    function isArray(v){ return Object.prototype.toString.call(v) === '[object Array]'; }
    function isObj(v){ return !!v && typeof v === 'object' && !isArray(v); }
    function clone(v){ return JSON.parse(JSON.stringify(v)); }
    function titleOf(node){ return node && (node.title_ja || node.titleJa || node.label || node.title || ''); }
    function findByTitle(node, title){
      if (!node) return null;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) {
          var got = findByTitle(node[i], title);
          if (got) return got;
        }
        return null;
      }
      if (isObj(node)) {
        if (titleOf(node) === title) return node;
        var keys = Object.keys(node);
        for (var j = 0; j < keys.length; j++) {
          var got2 = findByTitle(node[keys[j]], title);
          if (got2) return got2;
        }
      }
      return null;
    }
    function removeChildByTitle(arr, title){
      if (!isArray(arr)) return null;
      for (var i = 0; i < arr.length; i++) {
        if (titleOf(arr[i]) === title) return arr.splice(i, 1)[0];
      }
      return null;
    }
    function upsertByTitle(arr, node, insertAt){
      if (!isArray(arr) || !node) return;
      var t = titleOf(node);
      for (var i = 0; i < arr.length; i++) {
        if (titleOf(arr[i]) === t) {
          arr[i] = node;
          return;
        }
      }
      if (typeof insertAt === 'number') arr.splice(insertAt, 0, node);
      else arr.push(node);
    }
    function inferStem(node){
      if (!node) return '';
      var raw = '';
      try {
        raw = JSON.stringify(node).toLowerCase();
      } catch (e) {
        raw = String(titleOf(node) || '').toLowerCase();
      }
      if (raw.indexOf('seiryu') >= 0 || raw.indexOf('青龍') >= 0) return 'seiryu';
      if (raw.indexOf('byakko') >= 0 || raw.indexOf('白虎') >= 0) return 'byakko';
      if (raw.indexOf('suzaku') >= 0 || raw.indexOf('朱雀') >= 0) return 'suzaku';
      if (raw.indexOf('genbu') >= 0 || raw.indexOf('玄武') >= 0) return 'genbu';
      if (raw.indexOf('qilin') >= 0 || raw.indexOf('kirin') >= 0 || raw.indexOf('麒麟') >= 0) return 'qilin';
      return '';
    }
