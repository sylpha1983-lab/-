    function titleOf(node){ return node && (node.title_ja || node.label || ''); }
    function findChildByTitle(children, title){
      if (!isArray(children)) return null;
      for (var i = 0; i < children.length; i++) if (titleOf(children[i]) === title) return children[i];
      return null;
    }
    function findInTreeByTitle(node, title){
      if (!node) return null;
      if (titleOf(node) === title) return node;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) { var hit = findInTreeByTitle(node[i], title); if (hit) return hit; }
        return null;
      }
      if (typeof node !== 'object') return null;
