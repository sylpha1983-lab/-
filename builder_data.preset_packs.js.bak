(function(){
  "use strict";
  try {
    var db = (window.__PP_DB && window.__PP_DB.packs) || window.PRESET_PACKS_DB || window.__PRESET_PACKS_DB;
    if (!db || typeof db !== 'object') return;

    var ROLEPLAY_PARENT_KEY = '🎭 なりきりおすすめセット (Roleplay Recommended Sets)';
    var ADMIN_KEY = '🎭 なりきりおすすめセット｜管理者専用なりきり (Admin-only Roleplay)';
    var SPECIAL_TITLE_JA = '🧩 神獣・伝説特化コレクション';
    var SPECIAL_TITLE_EN = 'Mythic Special Collections';
    var MOVE_LIST = [
      { from: '🧛 吸血っ子', toJa: '🧛 吸血っ子特化コレクション', toEn: 'Vampire Girl Special Collection' },
      { from: '🪆 人形っ子', toJa: '🪆 人形っ子特化コレクション', toEn: 'Doll Girl Special Collection' }
    ];

    function isArray(v){ return Object.prototype.toString.call(v) === '[object Array]'; }
    function clone(v){ return JSON.parse(JSON.stringify(v)); }
    function titleOf(node){ return node && (node.title_ja || node.titleJa || node.label || node.title || ''); }
    function findByTitle(node, title){
      if (!node) return null;
      if (isArray(node)) {
        for (var i = 0; i < node.length; i++) {
          var got = findByTitle(node[i], title);
          if (got) return got;
        }
        return null;
      }
      if (typeof node === 'object') {
        if (titleOf(node) === title) return node;
        var keys = Object.keys(node);
        for (var j = 0; j < keys.length; j++) {
          var got2 = findByTitle(node[keys[j]], title);
          if (got2) return got2;
        }
      }
      return null;
    }
    function removeChildByTitle(arr, title) {
      if (!isArray(arr)) return null;
      for (var i = 0; i < arr.length; i++) {
        if (titleOf(arr[i]) === title) return arr.splice(i, 1)[0];
      }
      return null;
    }
    function upsertByTitle(arr, node) {
      if (!isArray(arr) || !node) return;
      var t = titleOf(node);
      for (var i = 0; i < arr.length; i++) {
        if (titleOf(arr[i]) === t) {
          arr[i] = node;
          return;
        }
      }
      arr.push(node);
    }

    var roleplayArr = db[ROLEPLAY_PARENT_KEY];
    if (!isArray(roleplayArr) || !roleplayArr.length) return;
    var roleplayRoot = findByTitle(roleplayArr, '🎭 なりきり');
    if (!roleplayRoot || !isArray(roleplayRoot.children)) return;

    var adminArr = db[ADMIN_KEY];
    if (!isArray(adminArr) || !adminArr.length) return;
    var adminRoot = findByTitle(adminArr, '🛡 管理者専用なりきり特化コレクション');
    if (!adminRoot || !isArray(adminRoot.children)) return;

    var specialRoot = null;
    for (var i = 0; i < roleplayRoot.children.length; i++) {
      if (titleOf(roleplayRoot.children[i]) === SPECIAL_TITLE_JA) {
        specialRoot = roleplayRoot.children[i];
        break;
      }
    }
    if (!specialRoot) {
      specialRoot = { title_ja: SPECIAL_TITLE_JA, title_en: SPECIAL_TITLE_EN, children: [] };
      var mythicIndex = -1, adminIndex = -1;
      for (var r = 0; r < roleplayRoot.children.length; r++) {
        var rt = titleOf(roleplayRoot.children[r]);
        if (rt === '神獣・伝説なりきり') mythicIndex = r;
        if (rt === '🛡 管理者専用なりきり特化コレクション') adminIndex = r;
      }
      var insertAt = adminIndex >= 0 ? adminIndex : roleplayRoot.children.length;
      if (mythicIndex >= 0) insertAt = mythicIndex + 1;
      roleplayRoot.children.splice(insertAt, 0, specialRoot);
    }
    if (!isArray(specialRoot.children)) specialRoot.children = [];

    for (var m = 0; m < MOVE_LIST.length; m++) {
      var spec = MOVE_LIST[m];
      var pulled = removeChildByTitle(adminRoot.children, spec.from);
      if (!pulled) continue;
      var moved = clone(pulled);
      moved.title_ja = spec.toJa;
      moved.title_en = spec.toEn;
      upsertByTitle(specialRoot.children, moved);
    }

    var preferredOrder = [
      '🐉 ドラゴンっ子特化コレクション',
      '😈 悪魔っ子特化コレクション',
      '🤖 機械っ子特化コレクション',
      '🪽 天使っ子特化コレクション',
      '🦊 狐っ子特化コレクション',
      '🧛 吸血っ子特化コレクション',
      '🪆 人形っ子特化コレクション'
    ];
    specialRoot.children.sort(function(a, b){
      var ai = preferredOrder.indexOf(titleOf(a));
      var bi = preferredOrder.indexOf(titleOf(b));
      if (ai < 0) ai = 999;
      if (bi < 0) bi = 999;
      return ai - bi;
    });

    if (window.__PP_DB) window.__PP_DB.packs = db;
    window.PRESET_PACKS_DB = db;
    window.__PRESET_PACKS_DB = db;
  } catch (e) {}
})();


