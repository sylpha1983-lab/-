    var orochiNode = orochiWrapper ? findChildByTitle(orochiWrapper.children, "⛩ 八岐祭祀蛇竜群") : findChildByTitle(serpentNode.children, "⛩ 八岐祭祀蛇竜群");
    var hydraNode = hydraWrapper ? findChildByTitle(hydraWrapper.children, "☠ 多首再生蛇竜群") : findChildByTitle(serpentNode.children, "☠ 多首再生蛇竜群");
    if (!orochiNode || !hydraNode) return;

    // Add new Orochi/Hydra entries to specific subgroup sections before rebuilding wrappers.
    function addToBucket(rootNode, bucketTitle, payloads){
      var bucket = findChildByTitle(rootNode.children, bucketTitle);
      if (!bucket) return;
      for (var i = 0; i < payloads.length; i++) {
        var sec = ensureSection(bucket, payloads[i].section);
        ensureItem(sec, payloads[i].item);
      }
    }

